---
interface Props {
  title: string;
  description?: string;
  maxWidth?: string;
}

const {
  title,
  description = 'Professional tools for image editing, format conversion, AI analysis, and video processing.',
  maxWidth = '1200px',
} = Astro.props;

const pathname = Astro.url.pathname;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{title}</title>
  <meta name="description" content={description}>
  <script defer src="/_vercel/insights/script.js"></script>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      background: linear-gradient(135deg, #0a0015 0%, #1a0033 50%, #2d1b4e 100%);
      background-attachment: fixed;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      position: relative;
      padding: 4rem 0;
      padding-top: calc(4rem + 60px);
    }

    .site-nav {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      height: 60px;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 2rem;
      background: rgba(10, 0, 21, 0.7);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(0, 212, 255, 0.2);
    }

    .site-nav .nav-logo {
      font-size: 1.1rem;
      font-weight: 700;
      background: linear-gradient(135deg, #ff1493 0%, #00d4ff 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      text-decoration: none;
      letter-spacing: 1px;
    }

    .site-nav .nav-links {
      display: flex;
      gap: 2rem;
      align-items: center;
    }

    .site-nav .nav-link {
      color: rgba(255, 255, 255, 0.7);
      text-decoration: none;
      font-size: 0.9rem;
      font-weight: 500;
      transition: color 0.3s ease;
      letter-spacing: 0.3px;
    }

    .site-nav .nav-link:hover {
      color: #00d4ff;
    }

    .site-nav .nav-link.active {
      color: #00d4ff;
    }

    @media (max-width: 480px) {
      .site-nav {
        padding: 0 1rem;
      }

      .site-nav .nav-links {
        gap: 1.2rem;
      }

      .site-nav .nav-link {
        font-size: 0.82rem;
      }
    }

    body::before {
      content: '';
      position: absolute;
      top: -50%;
      left: -50%;
      width: 200%;
      height: 200%;
      background: radial-gradient(circle, rgba(255, 20, 147, 0.1) 0%, transparent 50%);
      animation: pulse 8s ease-in-out infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 0.3; }
      50% { opacity: 0.6; }
    }

    .container {
      text-align: center;
      padding: 2rem;
      position: relative;
      z-index: 1;
      width: 100%;
    }

    h1 {
      font-size: 3.5rem;
      margin-bottom: 1rem;
      font-weight: 700;
      background: linear-gradient(135deg, #ff1493 0%, #00d4ff 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      text-shadow: 0 0 30px rgba(255, 20, 147, 0.5);
      letter-spacing: 2px;
    }

    footer {
      margin-top: 5rem;
      padding-top: 2rem;
      border-top: 1px solid rgba(0, 212, 255, 0.1);
      text-align: center;
      color: rgba(255, 255, 255, 0.5);
      font-size: 0.9rem;
    }

    footer a {
      color: #00d4ff;
      text-decoration: none;
      transition: color 0.3s ease;
    }

    footer a:hover {
      color: #ff1493;
    }

    @media (max-width: 768px) {
      body {
        padding: 2rem 0;
        padding-top: calc(2rem + 60px);
      }

      h1 {
        font-size: 2.5rem;
      }

      footer {
        margin-top: 3rem;
        font-size: 0.85rem;
      }
    }

    @media (max-width: 480px) {
      h1 {
        font-size: 2rem;
      }
    }
  </style>
</head>
<body>
  <nav class="site-nav">
    <a href="/" class="nav-logo">Pix3lTools</a>
    <div class="nav-links">
      <a href="/" class={`nav-link${pathname === '/' ? ' active' : ''}`}>Home</a>
      <a href="/docs" class={`nav-link${pathname.startsWith('/docs') ? ' active' : ''}`}>Docs</a>
      <a href="/privacy" class={`nav-link${pathname.startsWith('/privacy') ? ' active' : ''}`}>Privacy</a>
    </div>
  </nav>
  <div class="container" style={`max-width: ${maxWidth}`}>
    <slot />
  </div>
</body>
</html>
