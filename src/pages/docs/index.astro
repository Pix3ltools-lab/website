---
import BaseLayout from '../../layouts/BaseLayout.astro';

const articles = [
  {
    category: 'Getting Started',
    items: [
      {
        title: 'Introduction to Pix3lTools',
        description: 'An overview of the Pix3lTools ecosystem: what it is, what problems it solves, and how the tools work together.',
        slug: 'pix3ltools',
      },
      {
        title: 'Self-hosting with Docker',
        description: 'Deploy Pix3lBoard, Pix3lWiki, Pix3lPrompt, and Pix3lMCP on your own server using Docker Compose and pix3ltools-deploy.',
        slug: 'deployment',
      },
    ],
  },
  {
    category: 'Pix3lBoard',
    items: [
      {
        title: 'Pix3lBoard: Kanban for AI Creators',
        description: 'How Pix3lBoard extends the classic Kanban board with AI-specific fields: prompts, ratings, job numbers, Midjourney/Suno tracking, and a full REST API.',
        slug: 'pix3lboard',
      },
    ],
  },
  {
    category: 'Pix3lWiki',
    items: [
      {
        title: 'Pix3lWiki: Knowledge Base for Your Projects',
        description: 'How to use Pix3lWiki to create and organize documentation with Markdown, categories, version history, and Pix3lBoard linking.',
        slug: 'pix3lwiki',
      },
    ],
  },
  {
    category: 'Pix3lPrompt',
    items: [
      {
        title: 'Pix3lPrompt: AI Prompt Editor',
        description: 'An intelligent prompt editor for AI image, video, and audio generators. Craft, optimize, and manage prompts — 100% client-side, no account required.',
        slug: 'pix3lprompt',
      },
    ],
  },
  {
    category: 'Pix3lMCP',
    items: [
      {
        title: 'Pix3lMCP: Managing Pix3lBoard from Claude Code',
        description: 'How to install Pix3lMCP and use it from Claude Code to manage boards, lists, and cards directly from your AI assistant.',
        slug: 'pix3lmcp',
      },
    ],
  },
];
---
<BaseLayout
  title="Documentation - Pix3lTools"
  description="Guides and articles for the Pix3lTools ecosystem."
>
  <h1>Documentation</h1>
  <p class="subtitle">Guides, tutorials, and articles for the Pix3lTools ecosystem.</p>

  <div class="docs-content">
    {articles.map((section) => (
      <div class="doc-section">
        <h2 class="section-title">{section.category}</h2>
        <div class="articles-grid">
          {section.items.map((article) => (
            <a href={`/docs/${article.slug}`} class="article-card">
              <h3 class="article-title">{article.title}</h3>
              <p class="article-description">{article.description}</p>
              <span class="read-link">Read →</span>
            </a>
          ))}
        </div>
      </div>
    ))}
  </div>

  <div class="github-cta">
    <p>All Pix3lTools projects are open source.</p>
    <a href="https://github.com/Pix3ltools-lab" target="_blank" rel="noopener noreferrer" class="github-link">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
      </svg>
      Pix3ltools-lab on GitHub
    </a>
  </div>

  <footer>
    <p>&copy; 2026 Pix3lTools. <a href="/">Back to Home</a> &middot; <a href="/privacy">Privacy Policy</a></p>
  </footer>
</BaseLayout>

<style>
  .subtitle {
    font-size: 1.1rem;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 3rem;
    margin-top: 0.5rem;
  }

  .docs-content {
    text-align: left;
    width: 100%;
  }

  .doc-section {
    margin-bottom: 3rem;
  }

  .section-title {
    font-size: 1.4rem;
    font-weight: 600;
    color: #ff1493;
    margin-bottom: 1.5rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid rgba(255, 20, 147, 0.3);
    letter-spacing: 0.5px;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
  }

  .article-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(0, 212, 255, 0.2);
    border-radius: 12px;
    padding: 1.5rem;
    transition: all 0.3s ease;
    position: relative;
    text-decoration: none;
    display: block;
  }

  .article-card:hover {
    border-color: rgba(0, 212, 255, 0.4);
    background: rgba(255, 255, 255, 0.05);
    transform: translateY(-3px);
  }

  .article-title {
    font-size: 1rem;
    font-weight: 600;
    color: #00d4ff;
    margin-bottom: 0.75rem;
    line-height: 1.4;
  }

  .article-description {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.6);
    line-height: 1.6;
    margin-bottom: 1rem;
  }

  .read-link {
    font-size: 0.85rem;
    color: #ff1493;
    font-weight: 500;
  }

  .github-cta {
    margin-top: 4rem;
    padding: 2rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(0, 212, 255, 0.2);
    border-radius: 15px;
    text-align: center;
  }

  .github-cta p {
    color: rgba(255, 255, 255, 0.7);
    margin-bottom: 1rem;
  }

  .github-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #00d4ff;
    text-decoration: none;
    font-weight: 500;
    transition: all 0.3s ease;
  }

  .github-link svg {
    width: 20px;
    height: 20px;
    fill: currentColor;
  }

  .github-link:hover {
    color: #ff1493;
  }

  @media (max-width: 768px) {
    .articles-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
