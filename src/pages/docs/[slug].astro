---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  return docs.map((entry) => ({
    params: { slug: entry.id.replace(/\.md$/, '') },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---
<BaseLayout title={`${entry.data.title} — Pix3lTools Docs`} description={entry.data.description} maxWidth="900px">
  <a href="/docs" class="back-link">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
    Back to Docs
  </a>

  <article class="doc-article">
    <Content />
  </article>

  <footer>
    <p>&copy; 2026 Pix3lTools. <a href="/">Home</a> &middot; <a href="/docs">Docs</a> &middot; <a href="/privacy">Privacy Policy</a></p>
  </footer>
</BaseLayout>

<style>
  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #00d4ff;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.95rem;
    margin-bottom: 2.5rem;
    transition: all 0.3s ease;
  }

  .back-link svg {
    width: 16px;
    height: 16px;
    fill: none;
    stroke: currentColor;
    stroke-width: 2;
    transform: rotate(180deg);
  }

  .back-link:hover {
    color: #ff1493;
    gap: 0.75rem;
  }

  .doc-article {
    text-align: left;
    width: 100%;
    line-height: 1.8;
  }

  .doc-article :global(h1) {
    font-size: 2.5rem;
    font-weight: 700;
    background: linear-gradient(135deg, #ff1493 0%, #00d4ff 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 2rem;
    letter-spacing: 1px;
  }

  .doc-article :global(h2) {
    font-size: 1.5rem;
    font-weight: 600;
    color: #ff1493;
    margin-top: 3rem;
    margin-bottom: 1rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid rgba(255, 20, 147, 0.3);
  }

  .doc-article :global(h3) {
    font-size: 1.15rem;
    font-weight: 600;
    color: #00d4ff;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .doc-article :global(p) {
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 1rem;
  }

  .doc-article :global(ul),
  .doc-article :global(ol) {
    color: rgba(255, 255, 255, 0.8);
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .doc-article :global(li) {
    margin-bottom: 0.4rem;
  }

  .doc-article :global(a) {
    color: #00d4ff;
    text-decoration: underline;
    text-underline-offset: 3px;
    transition: color 0.3s ease;
  }

  .doc-article :global(a:hover) {
    color: #ff1493;
  }

  .doc-article :global(code) {
    background: rgba(0, 212, 255, 0.1);
    border: 1px solid rgba(0, 212, 255, 0.2);
    border-radius: 4px;
    padding: 0.15rem 0.45rem;
    font-size: 0.88em;
    color: #00d4ff;
    font-family: 'Fira Code', 'Cascadia Code', 'Consolas', monospace;
  }

  .doc-article :global(pre) {
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(0, 212, 255, 0.2);
    border-radius: 10px;
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    margin-bottom: 1.5rem;
  }

  .doc-article :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.9rem;
  }

  .doc-article :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }

  .doc-article :global(th) {
    background: rgba(255, 20, 147, 0.1);
    color: #ff1493;
    font-weight: 600;
    text-align: left;
    padding: 0.6rem 1rem;
    border-bottom: 1px solid rgba(255, 20, 147, 0.3);
  }

  .doc-article :global(td) {
    color: rgba(255, 255, 255, 0.8);
    padding: 0.6rem 1rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .doc-article :global(tr:hover td) {
    background: rgba(255, 255, 255, 0.02);
  }

  .doc-article :global(blockquote) {
    border-left: 3px solid #00d4ff;
    padding-left: 1rem;
    margin: 1.5rem 0;
    color: rgba(255, 255, 255, 0.6);
    font-style: italic;
  }

  .doc-article :global(hr) {
    border: none;
    border-top: 1px solid rgba(0, 212, 255, 0.15);
    margin: 2rem 0;
  }

  @media (max-width: 768px) {
    .doc-article :global(h1) {
      font-size: 1.8rem;
    }

    .doc-article :global(pre) {
      padding: 1rem;
      font-size: 0.82rem;
    }

    .doc-article :global(table) {
      font-size: 0.82rem;
    }

    .doc-article :global(th),
    .doc-article :global(td) {
      padding: 0.5rem 0.6rem;
    }
  }
</style>
