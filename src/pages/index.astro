---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
  {
    title: 'pix3lforge',
    lang: 'C++ / Qt',
    description: 'Professional cross-platform desktop image editor built with C++ and Qt 6.9. A powerful tool for advanced image manipulation and editing.',
    url: 'https://github.com/Pix3ltools-lab/pix3lforge',
  },
  {
    title: 'pix3lsense',
    lang: 'C++ / Qt',
    description: 'AI-powered image analysis and cataloging system. Automatically organize, analyze, and categorize your image collections with advanced machine learning.',
    url: 'https://github.com/Pix3ltools-lab/pix3lsense',
  },
  {
    title: 'pix3lframes',
    lang: 'C++ / Qt',
    description: 'High-performance video frame extractor. Extract individual frames from video files with precision and speed for analysis or editing purposes.',
    url: 'https://github.com/Pix3ltools-lab/pix3lframes',
  },
  {
    title: 'pix3liconv',
    lang: 'C++ / Qt',
    description: 'Versatile image format converter supporting PNG, JPEG, and SVG to ICO conversion. Perfect for creating icons from various image formats.',
    url: 'https://github.com/Pix3ltools-lab/pix3liconv',
  },
  {
    title: 'pix3lcover',
    lang: 'JavaScript',
    description: 'Web application for creating professional YouTube thumbnails. Design eye-catching covers for your videos with an intuitive web-based interface.',
    url: 'https://github.com/Pix3ltools-lab/pix3lcover',
  },
  {
    title: 'pix3lboard',
    lang: 'TypeScript / Next.js',
    description: 'The cloud Kanban for AI creators: prompts, rating, Midjourney/Suno tracking, job numbering, and secure sharing.',
    url: 'https://github.com/Pix3ltools-lab/pix3lboard',
  },
  {
    title: 'pix3lwiki',
    lang: 'TypeScript / Next.js',
    description: 'Wiki companion app for Pix3lBoard. Document, organize, and share knowledge with Markdown, categories, version history, and seamless board-card linking.',
    url: 'https://github.com/Pix3ltools-lab/pix3lwiki',
  },
  {
    title: 'pix3lprompt',
    lang: 'TypeScript / Next.js',
    description: 'An intelligent prompt editor for AI image, video and audio generators. Craft, refine, and manage prompts with a powerful web-based interface.',
    url: 'https://github.com/Pix3ltools-lab/pix3lprompt',
  },
  {
    title: 'pix3lmaps',
    lang: 'TypeScript / Next.js',
    description: 'Privacy-focused mind-mapping tool for content creators. Design maps with templates, custom nodes, and export as PNG or JSON — all data stays in your browser.',
    url: 'https://github.com/Pix3ltools-lab/pix3lmaps',
  },
  {
    title: 'pix3lMCP',
    lang: 'TypeScript / MCP',
    description: 'MCP server for Claude Code that lets you use pix3lboard directly from your AI assistant — manage boards, lists, and cards without leaving your workflow.',
    url: 'https://github.com/Pix3ltools-lab/pix3lmcp',
  },
];
---
<BaseLayout title="Pix3lTools - Professional Image & Video Tools">
  <img src="/banner.png" alt="Pix3lTools Banner" class="banner">
  <h1>Pix3lTools</h1>

  <p class="intro-text">
    Transform your creative workflow with specialized tools for image editing, format conversion, AI analysis, and video processing.
  </p>

  <section class="projects-section">
    <h2 class="section-title">Our Projects</h2>

    <div class="projects-grid">
      {projects.map((project) => (
        <div class="project-card">
          <div class="project-header">
            <h3 class="project-title">{project.title}</h3>
            <span class="project-lang">{project.lang}</span>
          </div>
          <p class="project-description">{project.description}</p>
          <a href={project.url} target="_blank" rel="noopener noreferrer" class="project-link">
            View on GitHub
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
              <path d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
            </svg>
          </a>
        </div>
      ))}
    </div>
  </section>

  <p class="social-title">Follow Us</p>
  <div class="social-links">
    <a href="https://x.com/pix3ltools" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="Follow us on X">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
      </svg>
    </a>

    <a href="https://github.com/Pix3ltools-lab" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="Visit our GitHub">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
      </svg>
    </a>
  </div>

  <footer>
    <p>&copy; 2026 Pix3lTools. Open Source Projects. Licensed under <a href="/LICENSE.txt" target="_blank">MIT License</a>.</p>
  </footer>
</BaseLayout>

<style>
  .banner {
    width: 100%;
    max-width: 800px;
    height: 280px;
    object-fit: cover;
    object-position: center;
    border-radius: 20px;
    box-shadow:
      0 0 40px rgba(255, 20, 147, 0.4),
      0 0 80px rgba(0, 212, 255, 0.3);
    margin-bottom: 3rem;
    animation: float 6s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }

  .intro-text {
    font-size: 1.2rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.8);
    max-width: 700px;
    margin: 3rem auto 0;
    text-align: center;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(0, 212, 255, 0.2);
    border-radius: 15px;
    padding: 2rem;
    transition: all 0.3s ease;
  }

  .intro-text:hover {
    border-color: rgba(0, 212, 255, 0.4);
    background: rgba(255, 255, 255, 0.05);
  }

  .projects-section {
    margin-top: 5rem;
    width: 100%;
  }

  .section-title {
    font-size: 2.5rem;
    font-weight: 600;
    background: linear-gradient(135deg, #ff1493 0%, #00d4ff 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 3rem;
    letter-spacing: 1px;
  }

  .projects-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-top: 2rem;
  }

  .project-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(0, 212, 255, 0.2);
    border-radius: 15px;
    padding: 2rem;
    transition: all 0.4s ease;
    text-align: left;
    position: relative;
    overflow: hidden;
  }

  .project-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255, 20, 147, 0.1), transparent);
    transition: left 0.6s ease;
  }

  .project-card:hover::before {
    left: 100%;
  }

  .project-card:hover {
    transform: translateY(-8px);
    border-color: #ff1493;
    box-shadow:
      0 0 30px rgba(255, 20, 147, 0.4),
      0 0 60px rgba(0, 212, 255, 0.2);
    background: rgba(255, 255, 255, 0.05);
  }

  .project-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1rem;
  }

  .project-title {
    font-size: 1.5rem;
    font-weight: 600;
    color: #00d4ff;
    margin-bottom: 0.5rem;
  }

  .project-lang {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: rgba(255, 20, 147, 0.2);
    border: 1px solid rgba(255, 20, 147, 0.4);
    border-radius: 20px;
    font-size: 0.75rem;
    color: #ff1493;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .project-description {
    color: rgba(255, 255, 255, 0.7);
    line-height: 1.6;
    margin-bottom: 1.5rem;
    font-size: 0.95rem;
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: #00d4ff;
    text-decoration: none;
    font-weight: 500;
    font-size: 0.9rem;
    transition: all 0.3s ease;
  }

  .project-link:hover {
    color: #ff1493;
    gap: 0.75rem;
  }

  .project-link svg {
    width: 16px;
    height: 16px;
    fill: currentColor;
  }

  .social-title {
    font-size: 1.2rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.8);
    margin-top: 3rem;
    margin-bottom: 1.5rem;
    letter-spacing: 1px;
  }

  .social-links {
    display: flex;
    gap: 2rem;
    justify-content: center;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.05);
    border: 2px solid rgba(0, 212, 255, 0.3);
    transition: all 0.3s ease;
    text-decoration: none;
  }

  .social-link svg {
    width: 28px;
    height: 28px;
    fill: #00d4ff;
    transition: all 0.3s ease;
  }

  .social-link:hover {
    background: rgba(255, 20, 147, 0.1);
    border-color: #ff1493;
    transform: translateY(-5px);
    box-shadow:
      0 0 20px rgba(255, 20, 147, 0.6),
      0 0 40px rgba(0, 212, 255, 0.4);
  }

  .social-link:hover svg {
    fill: #ff1493;
    filter: drop-shadow(0 0 8px rgba(255, 20, 147, 0.8));
  }

  @media (max-width: 768px) {
    .banner {
      max-width: 100%;
      height: 200px;
      margin-bottom: 2rem;
    }

    .projects-section {
      margin-top: 3rem;
    }

    .section-title {
      font-size: 2rem;
    }

    .projects-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .project-card {
      padding: 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .section-title {
      font-size: 1.5rem;
    }

    .project-title {
      font-size: 1.25rem;
    }

    .social-links {
      gap: 1.5rem;
      margin-top: 2rem;
    }

    .social-link {
      width: 50px;
      height: 50px;
    }

    .social-link svg {
      width: 24px;
      height: 24px;
    }
  }
</style>
